# 이 파일을 keystore.properties로 복사해서 채우세요.
# keystore.properties는 .gitignore에 등록돼있어 커밋 안 됩니다.
#
# storeFile 경로는 절대경로 권장 (예: C:/Users/이한민/keystores/custom-animation-alert.jks)
# 또는 프로젝트 루트 기준 상대경로

storeFile=../../keystores/custom-animation-alert-upload.jks
storePassword=PUT_YOUR_KEYSTORE_PASSWORD_HERE
keyAlias=upload
keyPassword=PUT_YOUR_KEY_PASSWORD_HERE
