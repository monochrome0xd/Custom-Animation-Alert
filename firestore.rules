rules_version = '2';

// Custom Animation Alert — Firestore 보안 규칙
// Firebase 콘솔 → Firestore Database → 규칙(Rules) 탭에 붙여넣고 "게시"하세요.
//
// 핵심:
//  - animations: 누구나 읽기, 본인만 생성/수정/삭제 (단 likes/downloadCount 카운터는 로그인 사용자면 증가 가능)
//  - 관리자(admin)는 타인 콘텐츠 삭제 + 신고 열람/처리 가능 (#40)
//  - reports: 작성자 본인만 쓰기, 관리자만 읽기/삭제 (#44)
//  - users/{uid}/blocked, users/{uid}/likes: 본인만 접근 (#46)
//  - profiles: 누구나 읽기(닉네임 중복확인), 본인만 쓰기

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== 헬퍼 =====
    function isSignedIn() {
      return request.auth != null;
    }

    // 관리자 식별 — ModerationStore.kt 의 ADMIN_EMAILS 와 동일하게 유지할 것.
    // (UID 기반으로 바꾸려면 request.auth.uid in ['<UID>'] 추가)
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'monochrome0xd@gmail.com';
    }

    // 수정 시 바뀐 필드가 카운터(likes/downloadCount)뿐인지
    function onlyCounters() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['likes', 'downloadCount']);
    }

    // ===== 마켓 콘텐츠 =====
    match /animations/{animationId} {
      allow read: if true;  // 공개 마켓 (비공개 항목은 클라이언트가 목록에서 숨김)

      allow create: if isSignedIn()
        && request.resource.data.creatorUid == request.auth.uid;

      // 본인/관리자는 전체 수정, 그 외 로그인 사용자는 카운터만 증가 가능 (좋아요/다운로드)
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.creatorUid == request.auth.uid)
        || (isSignedIn() && onlyCounters());

      // 본인 또는 관리자(부적절 콘텐츠 삭제, #40)
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.creatorUid == request.auth.uid);
    }

    // ===== 신고 (#44) =====
    // 문서 ID = {animationId}_{reporterUid}
    match /reports/{reportId} {
      // 작성자 본인만 생성/덮어쓰기 (reporterUid 위조 방지)
      allow create, update: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid;
      // 신고 열람/처리는 관리자만 (#40)
      allow read, delete: if isAdmin();
    }

    // ===== 프로필 (닉네임) =====
    match /profiles/{uid} {
      allow read: if true;  // 닉네임 중복 확인 + creatorName 표시
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // ===== 사용자별 데이터 =====
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;

      // 좋아요
      match /likes/{animationId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
      // 차단 목록 (#46)
      match /blocked/{blockedUid} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }
  }
}
